# Black Node ZW API - Environment Variables
# Copy this file to .env and fill in your values
# Then add all these to Vercel: Settings > Environment Variables

# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# Firebase Admin SDK (for API key validation and Firestore)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the ENTIRE JSON object as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"apiblacknodezw",...}

# ─── AI APIS (optional but recommended) ───────────────────────────────────────

# OpenAI - enables GPT-4, DALL-E 3, TTS
# Free fallbacks (Llama 3, Pollinations) are used if not set
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── SEARCH & IMAGE ────────────────────────────────────────────────────────────

# Google Custom Search - enables image search with Google
# DuckDuckGo fallback is used if not set
# https://developers.google.com/custom-search/v1/introduction
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Bing Image Search (alternative to Google)
# https://portal.azure.com - Cognitive Services > Bing Search
BING_SEARCH_API_KEY=

# ─── YOUTUBE ──────────────────────────────────────────────────────────────────

# YouTube Data API v3 - enables channel stats, video metadata
# oembed fallback is used if not set
# https://console.cloud.google.com > APIs > YouTube Data API v3
YOUTUBE_API_KEY=

# ─── MUSIC ────────────────────────────────────────────────────────────────────

# Spotify Web API - enables full track, artist, playlist data + search
# https://developer.spotify.com/dashboard/create
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── NEWS ─────────────────────────────────────────────────────────────────────

# NewsData.io - 200+ news sources (free tier: 200 req/day)
# BBC RSS fallback is used if not set
# https://newsdata.io/register
NEWSDATA_API_KEY=

# GNews (alternative news source)
# https://gnews.io/register
GNEWS_API_KEY=

# ─── IMAGE PROCESSING ─────────────────────────────────────────────────────────

# remove.bg - professional background removal
# https://www.remove.bg/api
REMOVEBG_API_KEY=

# PhotoRoom - alternative background removal
# https://www.photoroom.com/api
PHOTOROOM_API_KEY=

# HuggingFace - enables Stable Diffusion image generation fallback
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ─── SCREENSHOTS ──────────────────────────────────────────────────────────────

# ScreenshotOne - reliable website screenshot capture
# Free fallback (thum.io) is used if not set
# https://screenshotone.com
SCREENSHOTONE_API_KEY=

# ─── GITHUB ───────────────────────────────────────────────────────────────────

# GitHub Personal Access Token - raises rate limit from 60 to 5000 req/hour
# https://github.com/settings/tokens/new
GITHUB_TOKEN=

# ─── IP LOOKUP ────────────────────────────────────────────────────────────────

# ip-api.com Pro key - removes rate limits (free tier: 1000 req/day)
# https://members.ip-api.com
IPAPI_KEY=

# ─── MISC ─────────────────────────────────────────────────────────────────────

# API Ninjas - alternative facts endpoint
# https://api-ninjas.com
APININJAS_KEY=

NODE_ENV=production
